{
  "name": "godplans",
  "version": "1.7.0",
  "description": "Plan everything before anything. A single-command AI agent skill that produces an audit-aware, validated, agent-executable master plan before application code is written.",
  "keywords": [
    "agent-skills",
    "ai-agents",
    "planning",
    "claude-code",
    "codex",
    "cursor",
    "opencode",
    "spec-driven-development",
    "mdx",
    "prd",
    "architecture",
    "project-planning"
  ],
  "homepage": "https://github.com/hannsxpeter/godplans",
  "bugs": "https://github.com/hannsxpeter/godplans/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hannsxpeter/godplans.git"
  },
  "license": "MIT",
  "author": "aihxp (https://github.com/hannsxpeter)",
  "files": [
    "skills",
    "install.sh",
    "scripts",
    "requirements",
    "evals/cases",
    "evals/runners",
    "evals/README.md",
    "tests",
    "docs",
    "PROMPT.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "bash tests/run.sh",
    "catalog": "node skills/godplans/scripts/build-catalog.js",
    "catalog:check": "node skills/godplans/scripts/build-catalog.js --check",
    "version:sync": "node scripts/version-sync.js",
    "version:check": "node scripts/version-sync.js --check",
    "release:prepare": "node scripts/release-prepare.js",
    "lint": "bash scripts/lint.sh --all --verbose",
    "check": "npm run version:check && npm run catalog:check && npm run lint && npm test",
    "eval": "bash scripts/eval.sh",
    "eval:check": "bash scripts/eval.sh --check-cases",
    "build:prompt": "bash scripts/build-prompt.sh",
    "release:check": "bash scripts/release-check.sh",
    "install:skill": "sh install.sh",
    "prepack": "npm run check",
    "postpack": "echo 'Install the skill with: sh install.sh (or npx skills add hannsxpeter/godplans)'"
  }
}
